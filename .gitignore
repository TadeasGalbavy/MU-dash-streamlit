# ==========================================
# 1. STREAMLIT ŠPECIFICKÉ SÚBORY (NAJDÔLEŽITEJŠIE!)
# ==========================================
# V ŽIADNOM PRÍPADE nepushuj secrets.toml – obsahuje tvoje heslá a API kľúče
.streamlit/secrets.toml
.streamlit/config.toml

# Streamlit config a cache
.streamlit/
!.streamlit/apps/ # Ak by si tam mal náhodou nejakú špeciálnu štruktúru, ale štandardne ignoruj celý priečinok

# ==========================================
# 2. DÁTA A VEĽKÉ SÚBORY (DATA SCIENCE SAFE)
# ==========================================
# Ignoruj lokálne datasety – nepatria na GitHub (využi radšej cloud alebo ich sťahuj cez kód)
*.csv
*.xlsx
*.json
*.parquet
*.feather
*.pkl
*.pickle
*.h5
*.sqlite3

# Ak máš špeciálny priečinok na dáta, ignoruj ho celý
data/
datasets/

# ==========================================
# 3. VIRTUÁLNE PROSTREDIA (PYTHON)
# ==========================================
# Nikdy nepushuj nainštalované knižnice (na to slúži requirements.txt)
.venv/
.env/
venv/
ENV/
env/
bin/
lib/
include/
share/
pyvenv.cfg

# Poetry, Pipenv a Anaconda prostredia
.poetry/
.pypoetry/
.conda/
conda-env/

# ==========================================
# 4. CACHE A PREKOMPILOVANÝ KÓD
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# ==========================================
# 5. SYSTÉMOVÉ SÚBORY (OS-SPECIFIC)
# ==========================================
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ==========================================
# 6. IDE / EDITORY (VS Code, PyCharm...)
# ==========================================
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp